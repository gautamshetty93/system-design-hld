    {
      "id": "g_XJmc2oZuVnPWYa-Evf6",
      "type": "text",
      "x": 245,
      "y": 138,
      "width": 419.9996032714844,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 300306572,
      "version": 149,
      "versionNonce": 483676940,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773832324320,
      "link": null,
      "locked": false,
      "text": "Functional\n1) 1-1 send/recieve message(text messages)\n2) Group message support\n3) Last seen/User online/offline\n4) User login/authentication \n",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 143,
      "containerId": null,
      "originalText": "Functional\n1) 1-1 send/recieve message(text messages)\n2) Group message support\n3) Last seen/User online/offline\n4) User login/authentication \n",
      "lineHeight": 1.25
    },
    {
      "id": "yqpgWbLu9NAHHd1OPSIwa",
      "type": "text",
      "x": 914,
      "y": 143,
      "width": 278.3997802734375,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 347220876,
      "version": 142,
      "versionNonce": 127349684,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773832324320,
      "link": null,
      "locked": false,
      "text": "Non functional\n1) Scalability -> huge traffic\n2) Low latency\n3) Availability\n",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 118,
      "containerId": null,
      "originalText": "Non functional\n1) Scalability -> huge traffic\n2) Low latency\n3) Availability\n",
      "lineHeight": 1.25
    },
    {
      "id": "BrsbfhUcAsgGTIbCC4832",
      "type": "text",
      "x": 245,
      "y": 307,
      "width": 642.6595458984375,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1767158068,
      "version": 290,
      "versionNonce": 996056372,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773832324320,
      "link": null,
      "locked": false,
      "text": "Back of the envelop :\nTotal user -> 2B\nDAU -> 50M\n1 user - 10 msg -> 4 people in 1 day\ntotal msg per day = 50M * 40M\n                   = 2000M = 2Billion\n1 msg = 100 bytes = 200GB per day\n\nChat history for 10 years = 200GB*365*10 = 712TB or 0.72PB\n\nDesign of Chat Application\n",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 293,
      "containerId": null,
      "originalText": "Back of the envelop :\nTotal user -> 2B\nDAU -> 50M\n1 user - 10 msg -> 4 people in 1 day\ntotal msg per day = 50M * 40M\n                   = 2000M = 2Billion\n1 msg = 100 bytes = 200GB per day\n\nChat history for 10 years = 200GB*365*10 = 712TB or 0.72PB\n\nDesign of Chat Application\n",
      "lineHeight": 1.25
    },
