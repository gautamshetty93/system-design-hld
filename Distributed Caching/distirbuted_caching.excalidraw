      "originalText": "Distributed Caching",
      "lineHeight": 1.25
    },
    {
      "id": "e5gd_a9-0SWXSs3v1cynT",
      "type": "text",
      "x": 236,
      "y": 166,
      "width": 1441.678955078125,
      "height": 1550,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
