      "updated": 1774033769534,
      "link": null,
      "locked": false,
      "text": "\nFamous service mesh is Istio. \n- Side car proxy here is known as Envoy.\n- Configuration manager in this is Galley.\n- Traffic control manager is Pilot.\n- Security manager is Citadel",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 143,
      "containerId": null,
      "originalText": "\nFamous service mesh is Istio. \n- Side car proxy here is known as Envoy.\n- Configuration manager in this is Galley.\n- Traffic control manager is Pilot.\n- Security manager is Citadel",
      "lineHeight": 1.25
    },
