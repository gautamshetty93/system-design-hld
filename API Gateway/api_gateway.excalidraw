    {
      "id": "mQvOZAbYb6l6nGjev7Q_r",
      "type": "text",
      "x": 275,
      "y": 548,
      "width": 1352.018798828125,
      "height": 400,
      "angle": 0,
      "strokeColor": "#1e1e1e",
