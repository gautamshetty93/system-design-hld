      ],
      "updated": 1774012540974,
      "link": null,
      "locked": false,
      "text": "Signature\n- Encode JWT header and payload\nseparately using Base64 encoding\n-concatenate the encoded header with \".\"\n-Encode the signature generated in last step\n- Use RSA or HMAC to create digital sign",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 143,
      "containerId": null,
      "originalText": "Signature\n- Encode JWT header and payload\nseparately using Base64 encoding\n-concatenate the encoded header with \".\"\n-Encode the signature generated in last step\n- Use RSA or HMAC to create digital sign",
      "lineHeight": 1.25
    },
