    },
    {
      "id": "9dQOl9LWduuZpLV7GtwI-",
      "type": "text",
      "x": 314,
      "y": 171,
      "width": 958.9391479492188,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 640216276,
      "version": 644,
      "versionNonce": 160610772,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1774013109275,
      "link": null,
      "locked": false,
      "text": "It provides a secure way of transmitting information between parties as Json object\nThis information can be varied because its digitally signed using RSA(public/private key pair) etc.\n\nAdvantages :\n- Compact because of its size.\n= It is stateless/self container\n- It can be signed by RSA or HMAC\n- built in expiry mechanism\n- custom claim(additional data) can be added in JWT.\nWhere to use JWT :\n- Authentication(confirm the user identity)\n- Authorization(check the user permission for the resource)\n- SSO, authenticate once and use multiple applications\n",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 343,
      "containerId": null,
      "originalText": "It provides a secure way of transmitting information between parties as Json object\nThis information can be varied because its digitally signed using RSA(public/private key pair) etc.\n\nAdvantages :\n- Compact because of its size.\n= It is stateless/self container\n- It can be signed by RSA or HMAC\n- built in expiry mechanism\n- custom claim(additional data) can be added in JWT.\nWhere to use JWT :\n- Authentication(confirm the user identity)\n- Authorization(check the user permission for the resource)\n- SSO, authenticate once and use multiple applications\n",
      "lineHeight": 1.25
    },
